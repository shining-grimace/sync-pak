import { Button, CheckBox, ComboBox, HorizontalBox, LineEdit, ListView, Palette, ScrollView, VerticalBox } from "std-widgets.slint";
import { Dimensions } from "dimensions.slint";

export struct ProviderRow {
    id: string,
    name: string,
    kind: string,
    connection-summary: string,
}

export struct ConnectionRow {
    id: string,
    name: string,
    detail: string,
    mode: int,
    local-path: string,
    provider-name: string,
    remote-location: string,
    archive-retention: string,
}

export struct ActivityRow {
    id: string,
    title: string,
    detail: string,
    status: string,
    progress: string,
    result: string,
    can-cancel: bool,
    can-remove: bool,
}

export struct PreflightRow {
    path: string,
    status: string,
    detail: string,
}

export component AppWindow inherits Window {
    in-out property <int> page: 0;
    in-out property <string> app-version;
    in-out property <[ProviderRow]> providers;
    in-out property <[ConnectionRow]> connections;
    in-out property <int> connections-total;
    in-out property <int> providers-total;
    in-out property <int> connection-filter: 0;
    in-out property <[ActivityRow]> activity-rows;
    in-out property <string> active-activity-id;
    in-out property <string> active-activity-title;
    in-out property <string> active-activity-progress;
    in-out property <[string]> provider-names;
    in-out property <[string]> provider-buckets;
    in-out property <[string]> provider-verified-buckets;
    in-out property <string> status-message;
    in-out property <string> notice-message;
    in-out property <string> diagnostic-text;
    in-out property <bool> diagnostic-include-paths;
    in-out property <string> pending-provider-id;
    in-out property <string> pending-provider-name;
    in-out property <int> pending-connection-count;
    in-out property <[string]> pending-provider-connections;
    in-out property <string> provider-form-id;
    in-out property <string> provider-form-name;
    in-out property <int> provider-form-kind;
    in-out property <string> provider-form-account-id;
    in-out property <string> provider-form-region;
    in-out property <string> provider-form-bucket;
    in-out property <string> provider-form-access-key;
    in-out property <string> provider-form-secret-key;
    in-out property <string> provider-form-endpoint;
    in-out property <string> provider-form-session-token;
    in-out property <string> provider-form-original;
    in-out property <bool> provider-secret-visible: false;
    in-out property <bool> provider-advanced-expanded: false;
    in-out property <bool> provider-verifying: false;
    in-out property <string> pending-connection-id;
    in-out property <string> pending-connection-name;
    in-out property <string> connection-form-id;
    in-out property <string> connection-form-name;
    in-out property <int> connection-form-provider;
    in-out property <string> connection-form-bucket;
    in-out property <string> connection-form-remote;
    in-out property <string> connection-form-local;
    in-out property <int> connection-form-mode;
    in-out property <string> connection-form-retention: "1";
    in-out property <string> connection-form-original;
    in-out property <string> run-connection-id;
    in-out property <string> run-connection-name;
    in-out property <string> run-connection-mode;
    in-out property <string> run-archive-details;
    in-out property <bool> run-allows-both-ways;
    in-out property <int> run-direction: 0;
    in-out property <bool> preflight-loading: false;
    in-out property <bool> preflight-failed: false;
    in-out property <string> preflight-additions;
    in-out property <string> preflight-overwrites;
    in-out property <string> preflight-deletions;
    in-out property <string> preflight-skipped;
    in-out property <string> preflight-start-action;
    in-out property <bool> preflight-requires-mirror-confirmation: false;
    in-out property <bool> preflight-mirror-confirmed: false;
    in-out property <[PreflightRow]> preflight-items;
    in-out property <string> pending-cancel-activity-id;
    in-out property <string> pending-cancel-activity-name;
    callback show-providers();
    callback show-connections();
    callback show-add-provider();
    callback show-add-connection();
    callback show-welcome();
    callback show-privacy();
    callback show-activity();
    callback show-diagnostics();
    callback set-diagnostic-include-paths(bool);
    callback request-provider-delete(string);
    callback request-provider-edit(string);
    callback verify-provider();
    callback confirm-provider-delete();
    callback cancel-provider-delete();
    callback request-connection-delete(string);
    callback confirm-connection-delete();
    callback cancel-connection-delete();
    callback request-connection-edit(string);
    callback select-local-folder();
    callback select-connection-provider(int);
    callback save-provider(string, int, string, string);
    callback request-save-provider();
    callback cancel-save-provider();
    callback request-discard-provider();
    callback confirm-discard-provider();
    callback cancel-discard-provider();
    callback save-connection(string, int, string, string, string, int, string);
    callback request-discard-connection();
    callback confirm-discard-connection();
    callback cancel-discard-connection();
    callback cancel-activity(string);
    callback request-cancel-activity(string, string);
    callback confirm-cancel-activity();
    callback dismiss-cancel-activity();
    callback remove-queued-activity(string);
    callback clear-completed-activity();
    callback request-run-connection(string);
    callback choose-run-direction(int);
    callback begin-preflight();
    callback cancel-run-direction();
    callback set-connection-filter(int);

    init => { Palette.color-scheme = ColorScheme.light; }
    title: "SyncPak";
    preferred-width: 900px;
    preferred-height: 620px;
    min-width: 360px;
    min-height: 520px;
    background: #f7f2e8;

    VerticalBox {
        padding: 16px;
        spacing: 16px;

        VerticalBox {
            spacing: 6px;
            Text { text: "SYNCPAK"; color: #2c2925; font-size: 17px; font-weight: 800; letter-spacing: 2px; }
            HorizontalBox { spacing: 6px;
                Button { text: "Connections"; clicked => { root.show-connections(); } }
                Button { text: "Providers"; clicked => { root.show-providers(); } }
            }
            HorizontalBox { spacing: 6px;
                Button { text: "Activity"; clicked => { root.show-activity(); } }
                Button { text: "Privacy"; clicked => { root.show-privacy(); } }
                Rectangle { horizontal-stretch: 1; }
            }
        }

        if root.status-message != "" : Text {
            text: root.status-message;
            color: #7b241c;
            wrap: word-wrap;
        }

        if root.notice-message != "" : Text {
            text: root.notice-message;
            color: #23623a;
            wrap: word-wrap;
        }

        if root.active-activity-id != "" : Rectangle {
            background: #2c2925; border-radius: 8px; min-height: 62px;
            VerticalBox { padding: 12px; spacing: 8px;
                VerticalBox { spacing: 2px;
                    Text { text: root.active-activity-title; color: #fffaf0; font-weight: 700; }
                    Text { text: root.active-activity-progress; color: #fffaf0; wrap: word-wrap; }
                }
                Button { text: "Cancel"; clicked => { root.request-cancel-activity(root.active-activity-id, root.active-activity-title); } }
            }
        }

        if root.page == 0 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px;
            HorizontalBox {
                alignment: center;
                VerticalBox {
                    preferred-width: Dimensions.welcome-content-max-width;
                    max-width: Dimensions.welcome-content-max-width;
                    horizontal-stretch: 1;
                    spacing: 14px;
                    alignment: center;
                    Text { text: "Your files, your cloud."; color: #171512; font-size: 36px; font-weight: 800; horizontal-alignment: center; wrap: word-wrap; }
                    Text { text: "SyncPak copies folders directly between this device and cloud providers you choose. SyncPak does not operate an intermediary file service."; color: #454039; font-size: 18px; horizontal-alignment: center; wrap: word-wrap; max-width: Dimensions.welcome-content-max-width; }
                    Rectangle { height: 16px; background: transparent; }
                    Rectangle {
                        background: #fffaf0; border-color: #2c2925; border-width: 2px; border-radius: 12px; max-width: Dimensions.welcome-content-max-width; min-height: 92px;
                        Text { text: "Your provider credentials are protected using this device's secure storage and are sent only to that provider."; color: #2c2925; font-size: 16px; horizontal-alignment: center; vertical-alignment: center; wrap: word-wrap; x: 24px; width: parent.width - 48px; height: parent.height; }
                    }
                    Rectangle {
                        background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 12px; max-width: Dimensions.welcome-content-max-width; min-height: 106px;
                        VerticalBox { padding: 14px; spacing: 3px;
                            Text { text: "Choose how folders are copied"; font-weight: 700; horizontal-alignment: center; }
                            Text { text: "Add-only copies new files. Mirror can overwrite or delete only after review. Archive stores timestamped ZIP files."; color: #454039; horizontal-alignment: center; wrap: word-wrap; }
                        }
                    }
                    Rectangle { height: 16px; background: transparent; }
                    HorizontalBox { alignment: center; Button { text: "Add your first provider"; primary: true; preferred-width: Dimensions.welcome-action-max-width; max-width: Dimensions.welcome-action-max-width; clicked => { root.show-add-provider(); } } }
                    HorizontalBox { alignment: center; Button { text: "Read how SyncPak protects your privacy"; preferred-width: Dimensions.welcome-action-max-width; max-width: Dimensions.welcome-action-max-width; clicked => { root.show-privacy(); } } }
                }
            }
            }
        }

        if root.page == 1 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Providers"; color: #171512; font-size: 32px; font-weight: 800; }
            Text { text: "Provider credentials are kept in this device's protected storage."; color: #454039; wrap: word-wrap; }
            Button { text: "Add provider"; primary: true; clicked => { root.show-add-provider(); } }
            if root.providers.length == 0 : VerticalBox {
                spacing: 8px;
                Text { text: "No providers yet"; font-size: 22px; font-weight: 700; }
                Text { text: "Add credentials for Cloudflare R2, Backblaze B2, or AWS S3."; wrap: word-wrap; }
            }
            if root.providers.length > 0 : ScrollView {
                height: 260px;
                vertical-scrollbar-policy: always-on;
                VerticalBox { width: parent.width - 12px; spacing: 8px;
                    for provider in root.providers : Rectangle {
                        background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 8px; min-height: 82px;
                        VerticalBox { padding: 10px; spacing: 8px;
                            VerticalBox { spacing: 2px;
                                Text { text: provider.name; font-weight: 700; }
                                Text { text: provider.kind + " · Not verified"; color: #454039; }
                                Text { text: provider.connection-summary; color: #454039; }
                            }
                            HorizontalBox { spacing: 8px;
                                Button { text: "Edit"; clicked => { root.request-provider-edit(provider.id); } }
                                Button { text: "Delete"; clicked => { root.request-provider-delete(provider.id); } }
                                Rectangle { horizontal-stretch: 1; }
                            }
                        }
                    }
                }
            }
            }
        }

        if root.page == 2 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 10px;
            Text { text: root.provider-form-id == "" ? "Add provider" : "Edit " + root.provider-form-name; color: #171512; font-size: 32px; font-weight: 800; }
            Text { text: "Credentials are saved in protected storage before this provider is added."; wrap: word-wrap; }
            Text { text: "Provider name"; font-weight: 700; }
            provider-name := LineEdit { placeholder-text: "For example, Personal S3"; text <=> root.provider-form-name; enabled: !root.provider-verifying; }
            Text { text: "Provider type"; font-weight: 700; }
            provider-kind := ComboBox { model: ["Cloudflare R2", "Backblaze B2", "AWS S3"]; current-index <=> root.provider-form-kind; enabled: !root.provider-verifying; }
            if root.provider-form-kind == 0 : VerticalBox {
                spacing: 4px;
                Text { text: "Account ID"; font-weight: 700; }
                LineEdit { placeholder-text: "Cloudflare account ID"; text <=> root.provider-form-account-id; enabled: !root.provider-verifying; }
            }
            if root.provider-form-kind != 0 : VerticalBox {
                spacing: 4px;
                Text { text: "Region"; font-weight: 700; }
                LineEdit { placeholder-text: "For example, ap-southeast-2"; text <=> root.provider-form-region; enabled: !root.provider-verifying; }
            }
            Text { text: "Default bucket (optional)"; font-weight: 700; }
            LineEdit { placeholder-text: "Used and locked for connections that select this provider"; text <=> root.provider-form-bucket; enabled: !root.provider-verifying; }
            if root.provider-verified-buckets.length > 0 : VerticalBox {
                spacing: 4px;
                Text { text: "Verified available buckets"; color: #454039; }
                ComboBox {
                    model: root.provider-verified-buckets;
                    enabled: !root.provider-verifying;
                    selected => { root.provider-form-bucket = root.provider-verified-buckets[self.current-index]; }
                }
            }
            Text { text: "When set, new and edited connections using this provider use this bucket and cannot change it."; color: #454039; wrap: word-wrap; }
            if root.provider-form-kind == 1 : Text { text: "Create an application key in Backblaze B2; the same key pair works with its S3-compatible API. Do not use the master application key. Enter its S3 endpoint under Advanced."; color: #454039; wrap: word-wrap; }
            Text { text: root.provider-form-kind == 1 ? "Key ID" : "Access key ID"; font-weight: 700; }
            access-key := LineEdit { placeholder-text: root.provider-form-kind == 1 ? "Key ID" : "Access key ID"; text <=> root.provider-form-access-key; enabled: !root.provider-verifying; }
            Text { text: root.provider-form-kind == 1 ? "Application key" : "Secret access key"; font-weight: 700; }
            HorizontalBox {
                LineEdit { placeholder-text: root.provider-form-kind == 1 ? "Application key" : "Secret access key"; text <=> root.provider-form-secret-key; input-type: root.provider-secret-visible ? text : password; horizontal-stretch: 1; enabled: !root.provider-verifying; }
                Button { text: root.provider-secret-visible ? "Hide" : "Reveal"; enabled: !root.provider-verifying; clicked => { root.provider-secret-visible = !root.provider-secret-visible; } }
            }
            if root.provider-secret-visible : Text { text: "Make sure nobody else can see your screen."; color: #7b241c; wrap: word-wrap; }
            Button { text: root.provider-advanced-expanded ? "Hide advanced" : "Advanced"; enabled: !root.provider-verifying; clicked => { root.provider-advanced-expanded = !root.provider-advanced-expanded; } }
            if root.provider-advanced-expanded : VerticalBox {
                spacing: 4px;
                Text { text: "Custom endpoint"; font-weight: 700; }
                LineEdit { placeholder-text: "Optional S3-compatible endpoint"; text <=> root.provider-form-endpoint; enabled: !root.provider-verifying; }
                Text { text: "Session token"; font-weight: 700; }
                LineEdit { placeholder-text: "Optional temporary session token"; text <=> root.provider-form-session-token; input-type: root.provider-secret-visible ? text : password; enabled: !root.provider-verifying; }
            }
            Text { text: "Verify checks the credentials and lists available buckets without saving or changing cloud data."; color: #454039; wrap: word-wrap; }
            if root.provider-verifying : Text { text: "Checking these settings without changing cloud data…"; color: #454039; wrap: word-wrap; }
            VerticalBox {
                Button { text: "Back"; clicked => { root.request-discard-provider(); } }
                Button { text: root.provider-verifying ? "Verifying…" : "Verify provider"; enabled: !root.provider-verifying; clicked => { root.verify-provider(); } }
                Button { text: "Save without verifying"; primary: true; enabled: !root.provider-verifying; clicked => { root.request-save-provider(); } }
            }
            }
        }

        if root.page == 13 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Save without verifying?"; color: #171512; font-size: 28px; font-weight: 800; }
            Text { text: "This provider may not work until its credentials and access are verified."; wrap: word-wrap; }
            VerticalBox {
                Button { text: "Continue editing"; clicked => { root.cancel-save-provider(); } }
                Button { text: "Save without verifying"; primary: true; clicked => { root.save-provider(root.provider-form-name, root.provider-form-kind, root.provider-form-access-key, root.provider-form-secret-key); } }
            }
            }
        }

        if root.page == 15 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Discard unsaved changes?"; color: #171512; font-size: 28px; font-weight: 800; }
            Text { text: "Your changes to this provider have not been saved."; wrap: word-wrap; }
            VerticalBox {
                Button { text: "Continue editing"; clicked => { root.cancel-discard-provider(); } }
                Button { text: "Discard changes"; primary: true; clicked => { root.confirm-discard-provider(); } }
            }
            }
        }

        if root.page == 4 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Connections"; color: #171512; font-size: 32px; font-weight: 800; }
            Text { text: "A connection links a local folder with a folder in one cloud bucket."; color: #454039; wrap: word-wrap; }
            if root.providers-total == 0 : Button { text: "Add provider"; primary: true; clicked => { root.show-add-provider(); } }
            if root.providers-total > 0 : Button { text: "New connection"; primary: true; clicked => { root.show-add-connection(); } }
            VerticalBox { spacing: 6px;
                HorizontalBox { spacing: 6px;
                    Button { text: "All"; primary: root.connection-filter == 0; clicked => { root.set-connection-filter(0); } }
                    Button { text: "Add-only"; primary: root.connection-filter == 1; clicked => { root.set-connection-filter(1); } }
                }
                HorizontalBox { spacing: 6px;
                    Button { text: "Mirror"; primary: root.connection-filter == 2; clicked => { root.set-connection-filter(2); } }
                    Button { text: "Archive"; primary: root.connection-filter == 3; clicked => { root.set-connection-filter(3); } }
                }
            }
            if root.connections.length == 0 : VerticalBox {
                spacing: 8px;
                Text { text: root.connections-total == 0 ? "No connections yet" : "No matching connections"; font-size: 22px; font-weight: 700; }
                if root.connections-total == 0 && root.providers-total == 0 : Text { text: "Add a cloud provider, then create a connection to choose what to copy."; wrap: word-wrap; }
                if root.connections-total == 0 && root.providers-total > 0 : Text { text: "Create a connection to link a local folder with cloud storage."; wrap: word-wrap; }
                if root.connections-total > 0 : Text { text: "Choose another filter or create a new connection."; wrap: word-wrap; }
                if root.connections-total > 0 && root.connection-filter != 0 : Button { text: "Show all connections"; primary: true; clicked => { root.set-connection-filter(0); } }
            }
            if root.connections.length > 0 : ScrollView {
                height: 280px;
                vertical-scrollbar-policy: always-on;
                VerticalBox { width: parent.width - 12px; spacing: 8px;
                    for connection in root.connections : Rectangle {
                        background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 8px; min-height: 98px;
                        VerticalBox { padding: 10px; spacing: 8px;
                            VerticalBox { spacing: 3px;
                                Text { text: connection.name; font-weight: 700; }
                                Text { text: connection.detail; color: #454039; }
                                Text { text: "On this device: " + connection.local-path; color: #454039; wrap: word-wrap; }
                                Text { text: "In " + connection.provider-name + ": " + connection.remote-location; color: #454039; wrap: word-wrap; }
                                if connection.mode == 2 : Text { text: "Keeps the last " + connection.archive-retention + " archives"; color: #454039; }
                            }
                            HorizontalBox { spacing: 8px;
                                Button { text: "Run"; primary: true; clicked => { root.request-run-connection(connection.id); } }
                                Button { text: "Edit"; clicked => { root.request-connection-edit(connection.id); } }
                                Button { text: "Delete"; clicked => { root.request-connection-delete(connection.id); } }
                                Rectangle { horizontal-stretch: 1; }
                            }
                        }
                    }
                }
            }
            }
        }

        if root.page == 5 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 10px;
            Text { text: root.connection-form-id == "" ? "New connection" : "Edit " + root.connection-form-name; color: #171512; font-size: 32px; font-weight: 800; }
            Text { text: "Save only stores this connection. It does not transfer files."; wrap: word-wrap; }
            Text { text: "Connection name"; font-weight: 700; }
            connection-name := LineEdit { placeholder-text: "For example, Photos backup"; text <=> root.connection-form-name; }
            Text { text: "Used in the connection list and archive filenames."; color: #454039; wrap: word-wrap; }
            Text { text: "Provider"; font-weight: 700; }
            connection-provider := ComboBox { model: root.provider-names; enabled: root.provider-names.length > 0; current-index <=> root.connection-form-provider; selected => { root.select-connection-provider(self.current-index); } }
            Text { text: "Bucket"; font-weight: 700; }
            connection-bucket := LineEdit { placeholder-text: "Bucket name"; text <=> root.connection-form-bucket; enabled: connection-provider.current-index >= 0 && connection-provider.current-index < root.provider-buckets.length && root.provider-buckets[connection-provider.current-index] == ""; }
            if connection-provider.current-index >= 0 && connection-provider.current-index < root.provider-buckets.length && root.provider-buckets[connection-provider.current-index] != "" : Text {
                text: "This provider locks connections to its default bucket.";
                color: #454039; wrap: word-wrap;
            }
            if connection-provider.current-index >= 0 && connection-provider.current-index < root.provider-buckets.length && root.provider-buckets[connection-provider.current-index] == "" : Text {
                text: "Enter a bucket manually, or verify the provider first to see buckets available to its current credentials.";
                color: #454039; wrap: word-wrap;
            }
            Text { text: "Remote folder"; font-weight: 700; }
            connection-remote := LineEdit { placeholder-text: "Leave empty for the bucket root"; text <=> root.connection-form-remote; }
            Text { text: "Leave empty to use the root of the bucket."; color: #454039; wrap: word-wrap; }
            Text { text: "Local folder"; font-weight: 700; }
            VerticalBox { spacing: 6px;
                connection-local := LineEdit { placeholder-text: "Full local folder path"; text <=> root.connection-form-local; }
                Button { text: "Select folder"; clicked => { root.select-local-folder(); } }
            }
            Text { text: "Mode"; font-weight: 700; }
            connection-mode := ComboBox { model: ["Add-only", "Mirror", "Archive"]; current-index <=> root.connection-form-mode; }
            if connection-mode.current-index == 0 : Text {
                text: "Copies files that exist only at the source. Existing changed files are skipped, and nothing is overwritten or deleted.";
                color: #454039; wrap: word-wrap;
            }
            if connection-mode.current-index == 1 : Text {
                text: "Attempts to make the destination match the source. Overwrites and deletions are always shown for confirmation before the run starts.";
                color: #454039; wrap: word-wrap;
            }
            if connection-mode.current-index == 2 : VerticalBox {
                spacing: 4px;
                Text { text: "Creates a timestamped ZIP from the source and stores it at the destination. Older archives are removed according to this connection's retention setting."; color: #454039; wrap: word-wrap; }
                Text { text: "Keep last N archives"; font-weight: 700; }
                connection-retention := LineEdit { text <=> root.connection-form-retention; }
                Text { text: "After a new archive is saved successfully, older archives made by this connection are deleted until this many remain."; color: #454039; wrap: word-wrap; }
            }
            VerticalBox {
                Button { text: "Back"; clicked => { root.request-discard-connection(); } }
                Button { text: "Save"; primary: true; enabled: root.provider-names.length > 0; clicked => { root.save-connection(connection-name.text, connection-provider.current-index, connection-bucket.text, connection-remote.text, connection-local.text, connection-mode.current-index, root.connection-form-retention); } }
            }
            }
        }

        if root.page == 14 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Discard unsaved changes?"; color: #171512; font-size: 28px; font-weight: 800; }
            Text { text: "Your changes to this connection have not been saved."; wrap: word-wrap; }
            VerticalBox {
                Button { text: "Continue editing"; clicked => { root.cancel-discard-connection(); } }
                Button { text: "Discard changes"; primary: true; clicked => { root.confirm-discard-connection(); } }
            }
            }
        }

        if root.page == 3 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Privacy & About"; color: #171512; font-size: 32px; font-weight: 800; }
            Text { text: "Direct transfers"; font-size: 20px; font-weight: 700; }
            Text { text: "Your files move directly between this device and the cloud provider you configured. SyncPak does not receive or host them."; wrap: word-wrap; }
            Text { text: "Protected credentials"; font-size: 20px; font-weight: 700; }
            Text { text: "Provider credentials are stored using this device's protected facilities and are retrieved only when SyncPak connects to that provider."; wrap: word-wrap; }
            Text { text: "Data on this device"; font-size: 20px; font-weight: 700; }
            Text { text: "Connection settings are stored locally. Activity is kept in memory and cleared when SyncPak exits."; wrap: word-wrap; }
            Text { text: "File encryption"; font-size: 20px; font-weight: 700; }
            Text { text: "SyncPak does not encrypt file contents before transfer. Your provider and HTTPS connection may provide other forms of encryption."; wrap: word-wrap; }
            Text { text: "SyncPak " + root.app-version; color: #454039; }
            Button { text: "View redacted diagnostics"; clicked => { root.show-diagnostics(); } }
            Button { text: "Back"; clicked => { root.show-welcome(); } }
            }
        }

        if root.page == 8 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Diagnostics"; color: #171512; font-size: 32px; font-weight: 800; }
            Text { text: "This report excludes provider credentials. Paths are hidden unless you choose to include them."; wrap: word-wrap; }
            include-paths := CheckBox { text: "Include file and folder paths"; checked <=> root.diagnostic-include-paths; toggled => { root.set-diagnostic-include-paths(self.checked); } }
            if root.diagnostic-include-paths : Text { text: "Paths can contain personal information. Include them only when you trust the person receiving the report."; color: #7b241c; wrap: word-wrap; }
            Rectangle { background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 8px; min-height: 180px;
                ScrollView { x: 12px; y: 12px; width: parent.width - 24px; height: parent.height - 24px; vertical-scrollbar-policy: always-on;
                    Text { text: root.diagnostic-text; wrap: word-wrap; width: parent.width - 12px; }
                }
            }
            Button { text: "Back"; clicked => { root.show-privacy(); } }
            }
        }

        if root.page == 9 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Activity"; color: #171512; font-size: 32px; font-weight: 800; }
            Text { text: "Queued and completed operations appear here until SyncPak exits."; color: #454039; wrap: word-wrap; }
            if root.activity-rows.length > 0 : VerticalBox {
                spacing: 4px;
                Button { text: "Clear completed"; clicked => { root.clear-completed-activity(); } }
                Text { text: "Removes completed, failed, and cancelled entries only."; color: #454039; wrap: word-wrap; }
            }
            if root.activity-rows.length == 0 : Rectangle {
                background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 8px; min-height: 130px;
                VerticalBox { padding: 20px; spacing: 8px; alignment: center;
                    Text { text: "No activity this time"; font-size: 22px; font-weight: 700; horizontal-alignment: center; }
                    Text { text: "Queued and completed operations will appear here until SyncPak exits."; color: #454039; wrap: word-wrap; horizontal-alignment: center; }
                }
            }
            if root.activity-rows.length > 0 : ScrollView {
                height: 240px;
                vertical-scrollbar-policy: always-on;
                VerticalBox { width: parent.width - 12px; spacing: 8px;
                    for activity in root.activity-rows : Rectangle {
                        background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 8px; min-height: 86px;
                        VerticalBox { padding: 12px; spacing: 8px;
                            VerticalBox { spacing: 2px;
                                Text { text: activity.title + " · " + activity.status; font-weight: 700; }
                                Text { text: activity.detail; color: #454039; wrap: word-wrap; }
                                if activity.progress != "" : Text { text: activity.progress; color: #454039; wrap: word-wrap; }
                                if activity.result != "" : Text { text: activity.result; color: #454039; wrap: word-wrap; }
                            }
                            if activity.can-cancel || activity.can-remove : HorizontalBox {
                                spacing: 8px;
                                if activity.can-cancel : Button { text: "Cancel"; clicked => { root.request-cancel-activity(activity.id, activity.title); } }
                                if activity.can-remove : Button { text: "Remove"; clicked => { root.remove-queued-activity(activity.id); } }
                                Rectangle { horizontal-stretch: 1; }
                            }
                        }
                    }
                }
            }
            }
        }

        if root.page == 6 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Delete " + root.pending-provider-name + "?"; color: #171512; font-size: 28px; font-weight: 800; wrap: word-wrap; }
            Text { text: "This deletes its protected credentials and " + root.pending-connection-count + " connection(s). No cloud files will be deleted."; wrap: word-wrap; }
            if root.pending-provider-connections.length > 0 : VerticalBox {
                spacing: 3px;
                Text { text: "Connections that will be deleted"; font-weight: 700; }
                for connection-name in root.pending-provider-connections : Text { text: "• " + connection-name; color: #454039; wrap: word-wrap; }
            }
            VerticalBox {
                Button { text: "Cancel"; clicked => { root.cancel-provider-delete(); } }
                Button { text: "Delete provider and " + root.pending-connection-count + " connections"; primary: true; clicked => { root.confirm-provider-delete(); } }
            }
            }
        }

        if root.page == 7 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Delete " + root.pending-connection-name + "?"; color: #171512; font-size: 28px; font-weight: 800; wrap: word-wrap; }
            Text { text: "This removes the connection from SyncPak. It does not delete local or cloud files."; wrap: word-wrap; }
            VerticalBox {
                Button { text: "Cancel"; clicked => { root.cancel-connection-delete(); } }
                Button { text: "Delete connection"; primary: true; clicked => { root.confirm-connection-delete(); } }
            }
            }
        }
        if root.page == 12 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Cancel " + root.pending-cancel-activity-name + "?"; color: #171512; font-size: 28px; font-weight: 800; wrap: word-wrap; }
            Text { text: "Completed changes will not be undone. Work that has not started will be skipped."; wrap: word-wrap; }
            VerticalBox {
                Button { text: "Keep running"; clicked => { root.dismiss-cancel-activity(); } }
                Button { text: "Cancel operation"; primary: true; clicked => { root.confirm-cancel-activity(); } }
            }
            }
        }
        if root.page == 10 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: "Run " + root.run-connection-name; color: #171512; font-size: 32px; font-weight: 800; wrap: word-wrap; }
            Text { text: root.run-connection-mode + " connection"; color: #454039; }
            if root.run-archive-details != "" : Rectangle {
                background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 8px; min-height: 66px;
                Text { text: root.run-archive-details; color: #454039; wrap: word-wrap; x: 12px; y: 12px; width: parent.width - 24px; height: parent.height - 24px; }
            }
            Rectangle { background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 8px; min-height: 82px;
                VerticalBox { padding: 12px; spacing: 4px;
                    Text { text: "Upload"; font-weight: 700; }
                    Text { text: "Use the local folder as the source and cloud storage as the destination."; wrap: word-wrap; }
                    Button { text: "Choose upload"; primary: root.run-direction == 0; clicked => { root.choose-run-direction(0); } }
                }
            }
            Rectangle { background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 8px; min-height: 82px;
                VerticalBox { padding: 12px; spacing: 4px;
                    Text { text: "Download"; font-weight: 700; }
                    Text { text: "Use cloud storage as the source and the local folder as the destination."; wrap: word-wrap; }
                    Button { text: "Choose download"; primary: root.run-direction == 1; clicked => { root.choose-run-direction(1); } }
                }
            }
            if root.run-allows-both-ways : Rectangle { background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 8px; min-height: 82px;
                VerticalBox { padding: 12px; spacing: 4px;
                    Text { text: "Both ways"; font-weight: 700; }
                    Text { text: "Copy files found on only one side to the other. Changed files are skipped."; wrap: word-wrap; }
                    Button { text: "Choose both ways"; primary: root.run-direction == 2; clicked => { root.choose-run-direction(2); } }
                }
            }
            VerticalBox {
                Button { text: "Cancel"; clicked => { root.cancel-run-direction(); } }
                Button { text: "Continue"; primary: true; clicked => { root.begin-preflight(); } }
            }
            }
        }
        if root.page == 11 : ScrollView {
            vertical-scrollbar-policy: always-on;
            VerticalBox { width: parent.width - 12px; spacing: 12px;
            Text { text: root.preflight-failed ? "This operation cannot start" : (root.preflight-loading ? "Checking before anything changes" : "Ready to start"); color: #171512; font-size: 32px; font-weight: 800; wrap: word-wrap; }
            if root.preflight-loading : Text { text: "Listing files…"; font-weight: 700; }
            Text { text: "No files are changed during this check."; color: #454039; wrap: word-wrap; }
            if root.preflight-loading : Rectangle { background: #fffaf0; border-color: #2c2925; border-width: 1px; border-radius: 8px; min-height: 110px;
                Text { text: "Preflight will compare the local folder and cloud storage, then show additions, overwrites, deletions, and skipped files before anything starts."; wrap: word-wrap; x: 16px; y: 16px; width: parent.width - 32px; height: parent.height - 32px; }
            }
            if root.preflight-failed : Text { text: "Resolve the issues below, then run the connection again. No files were changed."; color: #7b241c; wrap: word-wrap; }
            if !root.preflight-loading && !root.preflight-failed : VerticalBox {
                spacing: 8px;
                VerticalBox { spacing: 4px;
                    HorizontalBox { spacing: 8px;
                        Text { text: root.preflight-additions; font-weight: 700; }
                        Text { text: root.preflight-overwrites; font-weight: 700; }
                    }
                    HorizontalBox { spacing: 8px;
                        Text { text: root.preflight-deletions; font-weight: 700; }
                        Text { text: root.preflight-skipped; font-weight: 700; }
                    }
                }
                if root.preflight-requires-mirror-confirmation : Text {
                    text: "SyncPak will attempt to make the destination match the source. Review every overwrite and deletion before continuing.";
                    color: #7b241c; wrap: word-wrap;
                }
                if root.preflight-items.length == 0 : Text {
                    text: "No changes are needed. The reviewed local folder and cloud storage already match for this direction.";
                    color: #23623a; wrap: word-wrap;
                }
                if root.preflight-items.length > 0 : ListView {
                    height: 180px;
                    vertical-scrollbar-policy: always-on;
                    for item in root.preflight-items : HorizontalBox {
                        spacing: 8px;
                        Text { text: item.status; width: 110px; color: #454039; }
                        VerticalBox { horizontal-stretch: 1; spacing: 2px;
                            Text { text: item.path; wrap: word-wrap; }
                            Text { text: item.detail; color: #454039; wrap: word-wrap; }
                        }
                    }
                }
                if root.preflight-requires-mirror-confirmation : CheckBox {
                    text: "I understand that the listed destination files will be overwritten or deleted.";
                    checked <=> root.preflight-mirror-confirmed;
                }
                Text { text: root.preflight-start-action + " will be available when transfer execution is connected."; color: #454039; wrap: word-wrap; }
            }
            VerticalBox {
                Button { text: "Back"; clicked => { root.cancel-run-direction(); } }
                if root.preflight-failed : Button { text: "Try again"; primary: true; clicked => { root.begin-preflight(); } }
                if !root.preflight-loading && !root.preflight-failed : Button { text: "Refresh review"; clicked => { root.begin-preflight(); } }
            }
            }
        }
        Rectangle { vertical-stretch: 1; }
    }
}
